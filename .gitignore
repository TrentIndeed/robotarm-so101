# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/

# Virtual envs
.venv/
venv/
env/

# Recorded datasets / model checkpoints (large, keep out of git)
# Keep the data/ folder tracked (via .gitkeep) but ignore everything in it.
data/*
!data/.gitkeep
outputs/
checkpoints/
*.safetensors
*.ckpt
wandb/

# LeRobot local cache (if pointed inside the repo)
.cache/

# Calibration files contain device-specific values — keep local
calibration/
*.json.local

# Machine-local GUI settings (persisted field values)
.app_settings.json

# Machine-local reach calibration (point-to-table mapping)
.ik_calib.json

# Downloaded MediaPipe model bundles (fetched on first vision-teleop run)
models/

# OS / editor
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
